---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { BUSINESS } from "../consts";
import { PROJECTS } from "../projects";
import { leadImage } from "../galleries";
const tel = `tel:${BUSINESS.phone.replace(/\s/g, "")}`;
const featured = PROJECTS.filter((p) => p.featured);
const heroImg = { src: "/hero.jpg", width: 1080, height: 596 };
// Hero trust strip reads the offer from consts; drop the "— through So Clean"
// credit for the thin strip (it's credited in full in the About section below).
const houseWash = BUSINESS.offer.split(" — ")[0];
const desc = "Painters and plasterers across north Auckland — new builds, repaints and renovations, done properly. Fully insured, Dulux Accredited.";
---
<Base title={BUSINESS.seoTitle} description={desc}>
  <Nav />
  <main>
    <section class="hero">
      <img
        class="hero-bg"
        src={heroImg.src}
        width={heroImg.width}
        height={heroImg.height}
        loading="eager"
        fetchpriority="high"
        alt="Black cedar and bagged-brick new build exterior at Mangawhai Estuary, painted by MH Painting"
      />
      <div class="hero-overlay"></div>
      <div class="hero-inner wrap">
        <h1>North Auckland painters and plasterers —<br />new builds, repaints and renovations.</h1>
        <p class="lead">Turning your vision into value — work that stands the test of time.</p>
        <p class="trust-strip">{BUSINESS.accreditations[0]} · Fully insured · {houseWash}</p>
        <div class="pills">
          <span class="pill"><b>{BUSINESS.experienceYears}+ yrs</b> experience</span>
          <span class="pill"><b>★ {BUSINESS.reviews.rating}</b> on Google</span>
        </div>
        <div class="cta-row">
          <a class="btn" href="/contact">Get a free quote</a>
          <a class="btn ghost" href="/projects">See our work</a>
        </div>
      </div>
    </section>

    <section class="wrap paint-scene">
      <div class="paint-throw" aria-hidden="true">
        <span class="paint-splat s1"></span>
        <span class="paint-splat s2"></span>
        <span class="paint-edge"></span>
      </div>
      <p class="eyebrow pc">What we do</p>
      <h2 class="pc" data-type>Painting &amp; plastering, done properly.</h2>
      <div class="grid3 paint-grid">
        {BUSINESS.services.map((s) => (
          <div class="cell">
            <h3>{s.title}</h3>
            <p>{s.blurb}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="wrap">
      <p class="eyebrow reveal">Why MH Painting</p>
      <h2 class="reveal edge" data-type>{BUSINESS.experienceYears} years on the tools.</h2>
      <div class="prose reveal">
        <p>Max has been painting for {BUSINESS.experienceYears}+ years — and that shows in the prep, the knowledge and the finish.</p>
        <p>Specialising in new builds, repaints and commercial painting across Auckland, from the North Shore and Hibiscus Coast through to Orewa, Silverdale and Whangaparāoa.</p>
        <p>For the right project we'll travel north — as you can see in our portfolio, we've worked on architectural new builds in Mangawhai, Langs Beach, Waipu and Warkworth.</p>
        <p>Serving builders and homeowners across Auckland and Northland — and every full exterior repaint comes with a free house wash through our partner <a href="https://www.soclean.co.nz/" target="_blank" rel="noopener noreferrer" style="text-decoration:underline">So Clean</a>, because the job isn't done until it looks the part.</p>
      </div>
    </section>

    <section class="wrap">
      <p class="eyebrow reveal">Recent work</p>
      <h2 class="reveal edge" data-type>Featured Works</h2>
      <div class="cards">
        {featured.map((p, i) => {
          const img = leadImage(p.slug);
          return (
            <a class="pcard reveal" style={`--i:${i}`} href={`/projects/${p.slug}`}>
              {img && (
                <div class="thumb">
                  <img
                    src={img.src}
                    width={img.width}
                    height={img.height}
                    loading="lazy"
                    alt={`${p.title} — photo 1`}
                  />
                </div>
              )}
              <span class="tag">{p.tag}</span>
              <h3>{p.title}</h3>
              <p>{p.body[0]}</p>
            </a>
          );
        })}
      </div>
      <p class="reveal" style="margin-top:24px"><a class="back" href="/projects">See all projects →</a></p>
    </section>

    <section class="wrap">
      <h2 class="reveal edge" data-type>Planning a new build or a repaint?</h2>
      <p class="lead reveal">Tell us a bit about the job and we'll come back to you with a free quote.</p>
      <div class="cta-row reveal">
        <a class="btn" href="/contact">Get a free quote</a>
        <a class="btn ghost" href={tel}>{BUSINESS.phone}</a>
      </div>
    </section>
  </main>
  <Footer />
  <style>
    h1 { font-size: clamp(40px, 7vw, 76px); font-weight: 600; line-height: 1.04; }

    /* Full-bleed photographic hero. cover is correct here: this is a
       decorative backdrop, not content (§9 governs galleries/content, which
       stay contain). Copy is overlaid in white, left-aligned, vertically
       centred. */
    .hero {
      position: relative;
      min-height: 80vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; z-index: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        linear-gradient(90deg, rgba(15,18,20,0.80) 0%, rgba(15,18,20,0.55) 45%, rgba(15,18,20,0.20) 100%),
        linear-gradient(0deg, rgba(15,18,20,0.55) 0%, rgba(15,18,20,0) 55%);
    }
    .hero-inner {
      position: relative; z-index: 2;
      width: 100%;
      padding-top: 7vh; padding-bottom: 7vh;
      color: #fff;
    }
    .hero-inner .eyebrow { color: #fff; opacity: 0.85; }
    .hero-inner h1 { color: #fff; text-shadow: 0 2px 18px rgba(0,0,0,0.35); }
    .hero-inner .lead { color: rgba(255,255,255,0.92); }
    .hero-inner .trust-strip {
      margin-top: 18px;
      font-size: 14px;
      letter-spacing: 0.01em;
      color: rgba(255,255,255,0.9);
    }
    /* Trust pills on dark */
    .hero-inner .pill {
      background: rgba(255,255,255,0.12); color: #fff;
      border-color: rgba(255,255,255,0.32);
    }
    .hero-inner .pill b { color: #fff; }
    /* Ghost CTA needs light borders on the dark image */
    .hero-inner .btn.ghost { color: #fff; border-color: rgba(255,255,255,0.6); }
    .hero-inner .btn.ghost:hover { border-color: #fff; color: #fff; }

    @media (max-width: 768px) {
      /* Top-align on mobile: centring tall content inside overflow:hidden
         was clipping the eyebrow + H1 behind the nav. */
      .hero { min-height: 72vh; align-items: flex-start; }
      .hero-inner { padding-top: 4vh; padding-bottom: 8vh; }
      /* Smaller headline so it fits without dominating the compact mobile view. */
      .hero-inner h1 { font-size: 30px; line-height: 1.08; }
      /* Shift the focal point left to the lighter side of the photo. */
      .hero-bg { object-position: 25% center; }
      /* Lighter top-to-bottom scrim — keeps the headline legible on the
         brighter area without darkening the whole image. */
      .hero-overlay {
        background: linear-gradient(180deg, rgba(22,20,18,0.25) 0%, rgba(22,20,18,0.5) 100%);
      }
    }

    /* Featured-card thumbnail: uniform box, cover (fills the box; full
       uncropped images live on the project detail galleries, which stay
       contain per §9). */
    .pcard .thumb {
      width: 100%; aspect-ratio: 3 / 2; margin-bottom: 16px;
      border: 1px solid var(--line); border-radius: 6px; overflow: hidden; background: #faf9f7;
    }
    .pcard .thumb img { width: 100%; height: 100%; display: block; object-fit: cover; }
  </style>
</Base>
