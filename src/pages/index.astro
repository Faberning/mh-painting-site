---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { BUSINESS } from "../consts";
import { PROJECTS } from "../projects";
import { GALLERIES, leadImage } from "../galleries";
const tel = `tel:${BUSINESS.phone.replace(/\s/g, "")}`;
const featured = PROJECTS.filter((p) => p.featured);
const heroImg = GALLERIES["board-and-batten-warkworth"][0];
const desc = "New build painters, plasterers and repaint specialists across north Auckland — Kumeu to the Hibiscus Coast. Dulux Accredited, fully insured.";
---
<Base title={BUSINESS.seoTitle} description={desc}>
  <Nav />
  <main>
    <section class="hero">
      <img
        class="hero-bg"
        src={heroImg.src}
        width={heroImg.width}
        height={heroImg.height}
        loading="eager"
        fetchpriority="high"
        alt="Black board-and-batten new build exterior in Warkworth, painted by MH Painting"
      />
      <div class="hero-overlay"></div>
      <div class="hero-inner wrap">
        <p class="eyebrow">New builds · Repaints · North Auckland</p>
        <h1>New build painters &amp; plasterers,<br />north Auckland.</h1>
        <p class="lead">Specialist new-build painting and plastering — plus quality repaints — across Kumeu, Riverhead, Silverdale, Millwater, Orewa and Warkworth. We travel the coast for the right job.</p>
        <div class="pills">
          <span class="pill"><b>{BUSINESS.experienceYears}+ yrs</b> experience</span>
          <span class="pill">Dulux Accredited</span>
          <span class="pill">Fully insured</span>
          <span class="pill"><b>★ {BUSINESS.reviews.rating}</b> on Google</span>
        </div>
        <div class="cta-row">
          <a class="btn" href="/contact">Get a free quote</a>
          <a class="btn ghost" href="/projects">See our work</a>
        </div>
        <p class="offer">{BUSINESS.offer}</p>
      </div>
    </section>

    <section class="wrap">
      <p class="eyebrow">What we do</p>
      <h2>Painting &amp; plastering, done properly.</h2>
      <div class="grid3">
        {BUSINESS.services.map((s, i) => (
          <div class="cell">
            <span class="num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{s.title}</h3>
            <p>{s.blurb}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="wrap">
      <p class="eyebrow">Why MH Painting</p>
      <h2>Seven years on the tools.</h2>
      <div class="prose">
        <p>Max Hindley has been painting for over {BUSINESS.experienceYears} years. MH Painting is a newer company, but the hands behind it aren't — and that shows in the prep, the paint systems and the finish.</p>
        <p>The focus is new builds and quality repaints, for builders and homeowners across the north-west and the Hibiscus Coast. We'll travel up the coast for the right project — the kind of coastal, dark-weatherboard work that has to be done properly.</p>
        <p>Every job is Dulux Accredited and fully insured. And every full exterior repaint comes with a free house wash through our partner So Clean.</p>
      </div>
    </section>

    <section class="wrap">
      <p class="eyebrow">Recent work</p>
      <h2>A few of the jobs.</h2>
      <div class="cards">
        {featured.map((p) => {
          const img = leadImage(p.slug);
          return (
            <a class="pcard" href={`/projects/${p.slug}`}>
              {img && (
                <div class="thumb">
                  <img
                    src={img.src}
                    width={img.width}
                    height={img.height}
                    loading="lazy"
                    alt={`${p.title} — photo 1`}
                  />
                </div>
              )}
              <span class="tag">{p.tag}</span>
              <h3>{p.title}</h3>
              <p>{p.body[0]}</p>
            </a>
          );
        })}
      </div>
      <p style="margin-top:24px"><a class="back" href="/projects">See all projects →</a></p>
    </section>

    <section class="wrap">
      <h2>Planning a new build or a repaint?</h2>
      <p class="lead">Tell us a bit about the job and we'll come back to you with a free quote.</p>
      <div class="cta-row">
        <a class="btn" href="/contact">Get a free quote</a>
        <a class="btn ghost" href={tel}>{BUSINESS.phone}</a>
      </div>
    </section>
  </main>
  <Footer />
  <style>
    h1 { font-size: clamp(40px, 7vw, 76px); font-weight: 600; line-height: 1.04; }

    /* Full-bleed photographic hero. cover is correct here: this is a
       decorative backdrop, not content (§9 governs galleries/content, which
       stay contain). Copy is overlaid in white, left-aligned, vertically
       centred. */
    .hero {
      position: relative;
      min-height: 80vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; z-index: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background:
        linear-gradient(90deg, rgba(15,18,20,0.80) 0%, rgba(15,18,20,0.55) 45%, rgba(15,18,20,0.20) 100%),
        linear-gradient(0deg, rgba(15,18,20,0.55) 0%, rgba(15,18,20,0) 55%);
    }
    .hero-inner {
      position: relative; z-index: 2;
      width: 100%;
      padding-top: 7vh; padding-bottom: 7vh;
      color: #fff;
    }
    .hero-inner .eyebrow { color: #fff; opacity: 0.85; }
    .hero-inner h1 { color: #fff; text-shadow: 0 2px 18px rgba(0,0,0,0.35); }
    .hero-inner .lead { color: rgba(255,255,255,0.92); }
    .hero-inner .offer { margin-top: 20px; font-size: 15px; color: rgba(255,255,255,0.82); }
    /* Trust pills on dark */
    .hero-inner .pill {
      background: rgba(255,255,255,0.12); color: #fff;
      border-color: rgba(255,255,255,0.32);
    }
    .hero-inner .pill b { color: #fff; }
    /* Ghost CTA needs light borders on the dark image */
    .hero-inner .btn.ghost { color: #fff; border-color: rgba(255,255,255,0.6); }
    .hero-inner .btn.ghost:hover { border-color: #fff; color: #fff; }

    @media (max-width: 640px) {
      .hero { min-height: 72vh; }
      .hero-overlay {
        background:
          linear-gradient(90deg, rgba(15,18,20,0.78) 0%, rgba(15,18,20,0.62) 100%),
          linear-gradient(0deg, rgba(15,18,20,0.55) 0%, rgba(15,18,20,0) 60%);
      }
    }

    /* Featured-card thumbnail: uniform box, contain (no crop to cover). */
    .pcard .thumb {
      width: 100%; aspect-ratio: 3 / 2; margin-bottom: 16px;
      border: 1px solid var(--line); border-radius: 6px; overflow: hidden; background: #faf9f7;
    }
    .pcard .thumb img { width: 100%; height: 100%; display: block; object-fit: contain; }
  </style>
</Base>
