---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { BUSINESS } from "../consts";
const tel = `tel:${BUSINESS.phone.replace(/\s/g, "")}`;
const desc = "Get a free quote from MH Painting — new builds and repaints across north Auckland. Call 020 4076 7979 or send a few details.";
---
<Base title="Contact" description={desc} path="/contact">
  <Nav />
  <main>
    <section class="wrap">
      <p class="eyebrow">Get in touch</p>
      <h1>Get a quote.</h1>
      <p class="lead">We cover north Auckland — Takapuna to Warkworth, and Long Bay across to Helensville: the North Shore, Hibiscus Coast, Rodney and the north-west. Commercial and residential.</p>

      <div class="contact-grid">
        <div>
          <p style="margin:18px 0 6px;"><strong>Call Max</strong><br /><a href={tel}>{BUSINESS.phone}</a></p>
          <p style="margin:6px 0 6px;"><strong>Email</strong><br /><a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a></p>
          <div class="hw"><strong>Free house wash</strong> with every full exterior repaint, through our partner <a href="https://www.soclean.co.nz/" target="_blank" rel="noopener noreferrer" style="text-decoration:underline">So Clean</a>. Mention it in your message.</div>

          <div class="reviews" id="reviews">
            <p class="rv-head">Google reviews · <span class="rv-gold">★</span> {BUSINESS.reviews.rating.toFixed(1)} from {BUSINESS.reviews.count}</p>
            <div class="rv-viewport">
              <div class="rv-track" id="rvTrack">
                {BUSINESS.reviews.featured.map((r, i) => (
                  <article class="rv-card" role="group" aria-roledescription="slide" aria-label={`Review ${i + 1} of ${BUSINESS.reviews.featured.length}`}>
                    <p class="rv-starline" aria-label={`${r.stars} out of 5 stars`}>{"★".repeat(r.stars)}</p>
                    <p class="rv-text">{r.text}</p>
                    <div class="rv-person">
                      <span class="rv-avatar" aria-hidden="true">{r.name.trim().charAt(0)}</span>
                      <span class="rv-meta">
                        <span class="rv-name">{r.name}</span>
                        <span class="rv-src">Google review</span>
                      </span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            <div class="rv-controls">
              <button class="rv-arrow" id="rvPrev" type="button" aria-label="Previous review">‹</button>
              <div class="rv-dots" id="rvDots">
                {BUSINESS.reviews.featured.map((_, i) => (
                  <button class="rv-dot" type="button" data-i={i} aria-label={`Show review ${i + 1}`}></button>
                ))}
              </div>
              <button class="rv-arrow" id="rvNext" type="button" aria-label="Next review">›</button>
            </div>
            <a class="rv-cta" href={BUSINESS.reviews.url} target="_blank" rel="noopener noreferrer">Leave a review on Google →</a>
          </div>
        </div>

        <div class="leadform">
          <p id="scopeNote" class="scope-note" hidden>Pre-filled from your job scope — add your details below and Max will pick it up already scoped.</p>
          <input type="text" id="company_url" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="field"><label for="f_name">Name</label><input id="f_name" type="text" required /></div>
          <div class="field"><label for="f_email">Email</label><input id="f_email" type="email" required /></div>
          <div class="field"><label for="f_phone">Phone</label><input id="f_phone" type="tel" /></div>
          <div class="field"><label for="f_details">Details</label><textarea id="f_details" rows="5" placeholder="New build or repaint? Where's the job, and roughly when? Mention the free house wash if you'd like it."></textarea></div>
          <p class="consent">By sending this you agree we can contact you about your enquiry. We don't share your details.</p>
          <button class="btn" id="f_send" type="button">Send enquiry</button>
          <p id="f_msg" class="fmsg" hidden></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <style>
    .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 44px; margin-top: 30px; }
    .hw { margin-top: 22px; padding: 16px 18px; border: 1px solid var(--line); border-radius: 6px; background: #fff; font-size: 14px; }
    .scope-note { margin: 0 0 18px; padding: 12px 14px; border-radius: 6px; background: color-mix(in srgb, var(--accent) 10%, #fff); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent); font-size: 13px; color: var(--ink); }
    .consent { font-size: 12px; color: var(--inkSoft); margin: 4px 0 14px; }
    .fmsg { margin-top: 14px; font-size: 14px; color: var(--accent); }
    @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }

    /* Google reviews carousel — one card at a time, on-brand. */
    .reviews { margin-top: 26px; }
    .rv-head { font-size: 13px; font-weight: 600; letter-spacing: 0.03em; color: var(--inkSoft); margin-bottom: 12px; }
    .rv-head .rv-gold { color: #e0a23c; }
    .rv-viewport { overflow: hidden; border: 1px solid var(--line); border-radius: 10px; background: #fff; }
    .rv-track { display: flex; transition: transform 0.45s ease; }
    .rv-card { flex: 0 0 100%; min-width: 100%; box-sizing: border-box; padding: 30px 28px; text-align: center; }
    .rv-starline { color: #e0a23c; letter-spacing: 3px; font-size: 16px; margin: 0; }
    .rv-text { margin: 14px auto 22px; font-size: 16px; line-height: 1.55; color: var(--ink);
      max-width: 36ch; min-height: 88px; display: flex; align-items: center; justify-content: center; }
    .rv-person { display: flex; align-items: center; justify-content: center; gap: 12px; }
    .rv-avatar { flex: none; width: 46px; height: 46px; border-radius: 50%; background: var(--accent); color: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      font-family: var(--display); font-size: 20px; font-weight: 600; }
    .rv-meta { text-align: left; display: flex; flex-direction: column; line-height: 1.3; }
    .rv-name { font-weight: 600; font-size: 15px; color: var(--ink); }
    .rv-src { font-size: 12px; color: var(--inkSoft); }
    .rv-controls { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 16px; }
    .rv-arrow { width: 38px; height: 38px; padding: 0; border-radius: 50%; border: 1px solid var(--line);
      background: #fff; color: var(--ink); font-size: 20px; line-height: 1; cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; transition: border-color .15s, color .15s; }
    .rv-arrow:hover { border-color: var(--accent); color: var(--accent); }
    .rv-arrow:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .rv-dots { display: flex; gap: 8px; }
    .rv-dot { width: 9px; height: 9px; padding: 0; border-radius: 50%; border: none;
      background: var(--line); cursor: pointer; transition: background .15s, transform .15s; }
    .rv-dot[aria-current="true"] { background: var(--accent); transform: scale(1.2); }
    .rv-dot:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .rv-cta { display: inline-block; margin-top: 18px; font-size: 14px; font-weight: 600;
      color: var(--accent); text-decoration: underline; }
    @media (prefers-reduced-motion: reduce) { .rv-track { transition: none; } }
  </style>
  <script is:inline>
    // Prefill from the homepage job scoper (?type=&areas=&size=&source=scoper).
    // Query params only — no localStorage/sessionStorage. The scope lands in
    // the same visible, editable textarea a hand-typed enquiry would use, so
    // it still goes through the one lead pipeline (honeypot, 2xx-fast, notify).
    (function () {
      const params = new URLSearchParams(window.location.search);
      const type = params.get('type');
      if (!type) return;
      const areas = (params.get('areas') || '').split(',').filter(Boolean);
      const size = params.get('size');
      const lines = ['Job: ' + type];
      if (areas.length) lines.push('Areas: ' + areas.join(', '));
      if (size) lines.push('Size: ' + size);
      const details = document.getElementById('f_details');
      if (details) details.value = lines.join('\n') + '\n\n';
      const note = document.getElementById('scopeNote');
      if (note) note.hidden = false;
      window.__leadSource = 'scoper';
    })();
  </script>
  <script is:inline>
    document.getElementById('f_send').addEventListener('click', async () => {
      const $ = (id) => document.getElementById(id);
      const msg = $('f_msg');
      const payload = {
        name: $('f_name').value.trim(),
        email: $('f_email').value.trim(),
        phone: $('f_phone').value.trim(),
        details: $('f_details').value.trim(),
        company_url: $('company_url').value,
        source: window.__leadSource || 'contact'
      };
      if (!payload.name || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(payload.email)) {
        msg.hidden = false; msg.textContent = 'Please add your name and a valid email.'; return;
      }
      const btn = $('f_send'); btn.disabled = true; btn.textContent = 'Sending…';
      try {
        const r = await fetch('/api/lead', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) });
        if (r.ok) { window.location.href = '/thank-you'; return; }
        throw new Error('bad status');
      } catch (e) {
        msg.hidden = false;
        msg.textContent = "Sorry — that didn't send. Please call us on 020 4076 7979.";
        btn.disabled = false; btn.textContent = 'Send enquiry';
      }
    });
  </script>
  <script is:inline>
    (function () {
      var root = document.getElementById('reviews');
      var track = document.getElementById('rvTrack');
      if (!root || !track) return;
      var n = track.children.length;
      if (n === 0) return;
      var dots = Array.prototype.slice.call(root.querySelectorAll('.rv-dot'));
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      var i = 0, timer = null;

      function go(k) {
        i = (k % n + n) % n;
        track.style.transform = 'translateX(' + (-i * 100) + '%)';
        dots.forEach(function (d, di) { d.setAttribute('aria-current', di === i ? 'true' : 'false'); });
      }
      function next() { go(i + 1); }
      function prev() { go(i - 1); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }
      function start() { stop(); if (!reduce.matches) timer = setInterval(next, 6000); }
      function restart() { stop(); start(); }

      document.getElementById('rvNext').addEventListener('click', function () { next(); restart(); });
      document.getElementById('rvPrev').addEventListener('click', function () { prev(); restart(); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () { go(parseInt(d.getAttribute('data-i'), 10)); restart(); });
      });

      // Pause on hover / keyboard focus
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);
      root.addEventListener('focusin', stop);
      root.addEventListener('focusout', start);

      // Arrow-key navigation when focus is inside the carousel
      root.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight') { next(); restart(); }
        else if (e.key === 'ArrowLeft') { prev(); restart(); }
      });

      // Bonus: touch swipe
      var x0 = null;
      var vp = root.querySelector('.rv-viewport');
      vp.addEventListener('touchstart', function (e) { x0 = e.touches[0].clientX; }, { passive: true });
      vp.addEventListener('touchend', function (e) {
        if (x0 === null) return;
        var dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) { (dx < 0 ? next : prev)(); restart(); }
        x0 = null;
      });

      // Re-evaluate auto-advance if the motion preference changes
      reduce.addEventListener && reduce.addEventListener('change', restart);

      go(0);
      start();
    })();
  </script>
</Base>
