---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
const desc = "Practical painting advice for north Auckland homeowners — when to repaint, coastal weather and dark colours, from MH Painting.";
---
<Base title="Blog" description={desc} path="/blog">
  <Nav />
  <main>
    <section class="wrap">
      <p class="eyebrow">Blog</p>
      <h1>Advice from the brush.</h1>
      <p class="lead">Plain, useful painting advice for north Auckland homes.</p>
      <div class="cards">
        <a class="pcard" href="/blog/6-signs-to-repaint-your-auckland-home-exterior">
          <span class="tag">Repaints</span>
          <h3>6 signs it's time to repaint your home's exterior</h3>
          <p>Auckland's UV, salt air and rain wear exterior paint down fast. Here are six clear signs it's time to repaint — and what each one is telling you.</p>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
