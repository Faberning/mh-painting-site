---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { PROJECTS } from "../../projects";
import { leadImage } from "../../galleries";
const desc = "From new builds to repaints, interiors to exteriors — clean, precise finishes across Auckland and the north. See MH Painting's project portfolio.";
---
<Base title="Our work" description={desc} path="/projects">
  <Nav />
  <main>
    <section class="wrap">
      <p class="eyebrow">Portfolio</p>
      <h1>Our work.</h1>
      <p class="lead">From new builds to renovations, interiors to exteriors — our portfolio shows the range and quality of our work across north Auckland. Clean, precise finishes and attention to detail on every job.</p>

      <div class="portfolio">
        {PROJECTS.map((p) => {
          const img = leadImage(p.slug);
          return (
            <a class="ptile" href={`/projects/${p.slug}`}>
              {img && (
                <img
                  src={img.src}
                  width={img.width}
                  height={img.height}
                  loading="lazy"
                  alt={`${p.title} — photo 1`}
                />
              )}
              <div class="ptile-cap">
                <span class="tag">{p.tag}</span>
                <h3>{p.title}</h3>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>
  <Footer />
  <style>
    /* Image-led portfolio grid (mirrors the old site's portfolio-grid):
       cover photo tiles with the title overlaid and a gentle hover zoom.
       Card thumbnails use cover (Task 8); detail-page galleries stay
       contain (§9). */
    .portfolio {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 36px;
    }
    .ptile {
      position: relative;
      display: block;
      aspect-ratio: 4 / 3;
      border-radius: 8px;
      overflow: hidden;
      background: #faf9f7;
      border: 1px solid var(--line);
    }
    .ptile img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .ptile:hover img { transform: scale(1.05); }
    .ptile-cap {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 18px;
      background: linear-gradient(0deg, rgba(15,18,20,0.80) 0%, rgba(15,18,20,0.18) 55%, rgba(15,18,20,0) 100%);
    }
    .ptile-cap .tag {
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: #fff; opacity: 0.85; font-weight: 600;
    }
    .ptile-cap h3 { color: #fff; font-size: 19px; margin-top: 4px; }
    @media (max-width: 820px) { .portfolio { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px) { .portfolio { grid-template-columns: 1fr; } }
  </style>
</Base>
