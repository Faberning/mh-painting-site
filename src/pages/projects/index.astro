---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { PROJECTS } from "../../projects";
import { leadImage } from "../../galleries";
const desc = "From new builds to repaints, interiors to exteriors — clean, precise finishes across Auckland and the north. See MH Painting's project portfolio.";
---
<Base title="Our work" description={desc} path="/projects">
  <Nav />
  <main>
    <section class="wrap">
      <p class="eyebrow">Portfolio</p>
      <h1>Our work.</h1>
      <p class="lead">From new builds to renovations, interiors to exteriors — our portfolio shows the range and quality of our work across Auckland and the north. Clean, precise finishes and attention to detail on every job.</p>
      <div class="cards">
        {PROJECTS.map((p) => {
          const img = leadImage(p.slug);
          return (
            <a class="pcard" href={`/projects/${p.slug}`}>
              {img && (
                <div class="thumb">
                  <img
                    src={img.src}
                    width={img.width}
                    height={img.height}
                    loading="lazy"
                    alt={`${p.title} — photo 1`}
                  />
                </div>
              )}
              <span class="tag">{p.tag}</span>
              <h3>{p.title}</h3>
              <p>{p.body[0]}</p>
            </a>
          );
        })}
      </div>
    </section>
  </main>
  <Footer />
  <style>
    /* Index-card thumbnail: small fixed-aspect box, cover is fine here — the
       full uncropped image lives on the project detail page (galleries stay
       contain per §9). Mirrors the homepage featured-card treatment. */
    .pcard .thumb {
      width: 100%; aspect-ratio: 3 / 2; margin-bottom: 16px;
      border: 1px solid var(--line); border-radius: 6px; overflow: hidden; background: #faf9f7;
    }
    .pcard .thumb img { width: 100%; height: 100%; display: block; object-fit: cover; }
  </style>
</Base>
