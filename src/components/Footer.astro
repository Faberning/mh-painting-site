---
import { BUSINESS } from "../consts";
const tel = `tel:${BUSINESS.phone.replace(/\s/g, "")}`;
const year = new Date().getFullYear();
---
<footer class="site">
  <div class="wrap frow">
    <div>
      <img class="footer-mark" src={BUSINESS.logo} alt="mh painting" width="68" height="40" />
      <strong>{BUSINESS.legalName}</strong><br />
      {BUSINESS.experienceYears}+ years' experience · Dulux Accredited · Fully insured
      {/* Dulux Accredited badge — accreditation runs to Dec 2026; remove/refresh if it lapses. */}
      <img class="dulux-badge" src="/dulux-accredited.png" alt="Dulux Accredited Painter" width="375" height="40" />
    </div>
    <div>
      <a href={tel}>{BUSINESS.phone}</a> · <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a><br />
      Serving north Auckland — Takapuna to Warkworth, Long Bay to Helensville.
    </div>
    <div>
      <a href={BUSINESS.reviews.url}>★ {BUSINESS.reviews.rating} on Google ({BUSINESS.reviews.count} reviews)</a><br />
      © {year} {BUSINESS.legalName}
    </div>
  </div>
  <style>
    /* Charcoal footer: the monochrome wordmark is inverted to white. */
    .footer-mark { height: 40px; width: auto; display: block; margin-bottom: 14px; filter: brightness(0) invert(1); }
    .dulux-badge { display: block; width: 210px; max-width: 100%; height: auto; margin-top: 16px; border-radius: 3px; }
  </style>
</footer>
