---
import { BUSINESS } from "../consts";
const tel = `tel:${BUSINESS.phone.replace(/\s/g, "")}`;
const year = new Date().getFullYear();
---
<footer class="site">
  <div class="wrap frow">
    <div>
      <img class="footer-mark" src={BUSINESS.logo} alt="mh painting" width="61" height="36" />
      <strong>{BUSINESS.legalName}</strong><br />
      {BUSINESS.experienceYears}+ years' experience · Dulux Accredited · Fully insured
    </div>
    <div>
      <a href={tel}>{BUSINESS.phone}</a> · <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a><br />
      Serving north Auckland — Takapuna to Warkworth, Long Bay to Helensville.
    </div>
    <div>
      <a href={BUSINESS.reviews.url}>★ {BUSINESS.reviews.rating} on Google ({BUSINESS.reviews.count} reviews)</a><br />
      © {year} {BUSINESS.legalName}
    </div>
  </div>
  <style>
    .footer-mark { height: 36px; width: auto; display: block; margin-bottom: 12px; }
  </style>
</footer>
