---
// Base.astro — every page wraps in this. Owns the SEO head so no page can
// ship without a title, description, canonical and OG tags. The check-gate
// asserts these exist in the built HTML.
import { BUSINESS } from "../consts";
import Schema from "../components/Schema.astro";

interface Props {
  title: string;
  description: string;
  path?: string; // e.g. "/services/industrial-coatings"
  noindex?: boolean;
}
const { title, description, path = "", noindex = false } = Astro.props;
const canonical = `${BUSINESS.url}${path}`;
const fullTitle = path === "" ? title : `${title} — ${BUSINESS.name}`;
const b = BUSINESS.brand;
---
<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:image" content={`${BUSINESS.url}/og-wordmark.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${BUSINESS.url}/og-wordmark.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <Schema />
    <style define:vars={{ bg: b.bg, ink: b.ink, inkSoft: b.inkSoft, accent: b.accent, line: b.line, fontDisplay: b.fontDisplay, fontBody: b.fontBody }}>
      :root {
        --bg: var(--bg); --ink: var(--ink); --inkSoft: var(--inkSoft);
        --accent: var(--accent); --line: var(--line);
        --display: var(--fontDisplay); --body: var(--fontBody);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg); color: var(--ink);
        font-family: var(--body); font-weight: 400;
        font-size: 17px; line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
    </style>
    <style is:global>
      h1, h2, h3 { font-family: var(--display); line-height: 1.05; letter-spacing: -0.02em; }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1140px; margin: 0 auto; padding: 0 6vw; }
      .eyebrow { font-family: var(--body); font-size: 12px; letter-spacing: 0.22em;
        text-transform: uppercase; color: var(--accent); font-weight: 600; margin-bottom: 18px; }
      .lead { font-size: clamp(18px, 2.3vw, 22px); color: var(--inkSoft); max-width: 640px; line-height: 1.55; }
      .btn { display: inline-block; background: var(--accent); color: #fff; font-weight: 600;
        padding: 14px 26px; border-radius: 4px; font-size: 15px; transition: transform .15s ease, background .15s ease; }
      .btn:hover { transform: translateY(-2px); }
      .btn.ghost { background: transparent; color: var(--ink); border: 1px solid var(--line); }
      .btn.ghost:hover { border-color: var(--accent); color: var(--accent); }
      .cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 32px; }
      section { padding: 7vh 0; }
      h2 { font-size: clamp(28px, 4.4vw, 46px); font-weight: 600; margin-bottom: 8px; }
      h3 { font-weight: 600; }
      /* site chrome */
      nav.site { display: flex; justify-content: space-between; align-items: center;
        padding: 18px 6vw; border-bottom: 1px solid var(--line); position: sticky; top: 0;
        background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px); z-index: 50; }
      nav.site .brand img { height: 30px; width: auto; display: block; }
      nav.site .links { display: flex; gap: 22px; align-items: center; font-size: 15px; font-weight: 500; }
      nav.site .links a:hover { color: var(--accent); }
      nav.site .links .call { background: var(--accent); color: #fff; padding: 9px 16px; border-radius: 4px; }
      footer.site { border-top: 1px solid var(--line); padding: 6vh 0; margin-top: 4vh; font-size: 14px; color: var(--inkSoft); }
      footer.site .frow { display: flex; justify-content: space-between; gap: 30px; flex-wrap: wrap; }
      footer.site strong { color: var(--ink); }
      footer.site a:hover { color: var(--accent); }
      .pills { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 26px; }
      .pill { border: 1px solid var(--line); border-radius: 999px; padding: 7px 15px; font-size: 13px;
        font-weight: 500; color: var(--ink); background: #fff; }
      .pill b { color: var(--accent); }
      .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
        background: var(--line); border: 1px solid var(--line); margin-top: 36px; }
      .grid3 .cell { background: var(--bg); padding: 30px 26px; }
      .grid3 .num { font-family: var(--display); color: var(--accent); font-size: 15px; }
      .grid3 h3 { font-size: 20px; margin: 12px 0 8px; }
      .grid3 p { font-size: 14px; color: var(--inkSoft); }
      .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 36px; }
      .pcard { display: block; border: 1px solid var(--line); border-radius: 8px; background: #fff;
        padding: 26px 24px; transition: transform .15s ease, border-color .15s ease; }
      .pcard:hover { transform: translateY(-3px); border-color: var(--accent); }
      .pcard .tag { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); font-weight: 600; }
      .pcard h3 { font-size: 21px; margin: 8px 0 8px; }
      .pcard p { font-size: 14px; color: var(--inkSoft); }
      .prose { max-width: 720px; }
      .prose p { margin-bottom: 18px; }
      .prose h2 { font-size: clamp(24px, 3.2vw, 34px); margin: 36px 0 12px; }
      .back { font-size: 14px; color: var(--accent); font-weight: 600; }
      .field { display: block; margin-bottom: 16px; }
      .field label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
      .field input, .field textarea { width: 100%; padding: 12px 14px; border: 1px solid var(--line);
        border-radius: 4px; font: inherit; background: #fff; color: var(--ink); }
      .hp { position: absolute; left: -9999px; }
      @media (max-width: 820px) { .grid3 { grid-template-columns: 1fr; } .cards { grid-template-columns: 1fr; }
        nav.site .links { gap: 14px; font-size: 14px; } }
      @media (max-width: 560px) {
        nav.site { flex-wrap: wrap; gap: 12px; }
        nav.site .links { width: 100%; justify-content: space-between; gap: 10px; }
        nav.site .brand img { height: 28px; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
