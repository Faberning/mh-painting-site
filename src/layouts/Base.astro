---
// Base.astro — every page wraps in this. Owns the SEO head so no page can
// ship without a title, description, canonical and OG tags. The check-gate
// asserts these exist in the built HTML.
import { BUSINESS } from "../consts";
import Schema from "../components/Schema.astro";

interface Props {
  title: string;
  description: string;
  path?: string; // e.g. "/services/industrial-coatings"
  noindex?: boolean;
}
const { title, description, path = "", noindex = false } = Astro.props;
const canonical = `${BUSINESS.url}${path}`;
const fullTitle = path === "" ? title : `${title} — ${BUSINESS.name}`;
const b = BUSINESS.brand;
---
<!doctype html>
<html lang="en-NZ" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Wet Edge motion: flip no-js→js BEFORE paint so animated states only ever
         apply when JS runs. JS-off (and crawlers) keep the fully-rendered static
         page — every headline/body word is real DOM text, presentation-only motion. -->
    <script is:inline>
      document.documentElement.classList.remove("no-js");
      document.documentElement.classList.add("js");
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:image" content={`${BUSINESS.url}/og-wordmark.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${BUSINESS.url}/og-wordmark.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <Schema />
    <style define:vars={{ bg: b.bg, ink: b.ink, inkSoft: b.inkSoft, accent: b.accent, line: b.line, fontDisplay: b.fontDisplay, fontBody: b.fontBody }}>
      :root {
        --bg: var(--bg); --ink: var(--ink); --inkSoft: var(--inkSoft);
        --accent: var(--accent); --line: var(--line);
        --display: var(--fontDisplay); --body: var(--fontBody);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg); color: var(--ink);
        font-family: var(--body); font-weight: 400;
        font-size: 17px; line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
    </style>
    <style is:global>
      h1, h2, h3 { font-family: var(--display); line-height: 1.05; letter-spacing: -0.02em; }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1140px; margin: 0 auto; padding: 0 6vw; }
      .eyebrow { font-family: var(--body); font-size: 12px; letter-spacing: 0.22em;
        text-transform: uppercase; color: var(--accent); font-weight: 600; margin-bottom: 18px; }
      .lead { font-size: clamp(18px, 2.3vw, 22px); color: var(--inkSoft); max-width: 640px; line-height: 1.55; }
      .btn { display: inline-block; background: var(--accent); color: #fff; font-weight: 600;
        padding: 14px 26px; border-radius: 4px; font-size: 15px; transition: transform .15s ease, background .15s ease; }
      .btn:hover { transform: translateY(-2px); }
      .btn.ghost { background: transparent; color: var(--ink); border: 1px solid var(--line); }
      .btn.ghost:hover { border-color: var(--accent); color: var(--accent); }
      .cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 32px; }
      section { padding: 9vh 0; }
      h2 { font-size: clamp(28px, 4.4vw, 46px); font-weight: 600; margin-bottom: 8px; }
      h3 { font-weight: 600; }
      /* site chrome */
      nav.site { display: flex; justify-content: space-between; align-items: center;
        padding: 18px 6vw; border-bottom: 1px solid var(--line); position: sticky; top: 0;
        background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px); z-index: 50; }
      nav.site .brand img { height: 192px; width: auto; display: block; }
      nav.site .links { display: flex; gap: 22px; align-items: center; font-size: 15px; font-weight: 500; }
      nav.site .links a:hover { color: var(--accent); }
      nav.site .links .call { background: var(--accent); color: #fff; padding: 9px 16px; border-radius: 4px; }
      footer.site { background: #221F1C; color: #fff; padding: 8vh 0 7vh; margin-top: 6vh; font-size: 14px; }
      footer.site .frow { display: flex; justify-content: space-between; gap: 30px; flex-wrap: wrap; }
      footer.site strong { color: #fff; }
      footer.site a:hover { color: var(--accent); }
      .pills { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 26px; }
      .pill { border: 1px solid var(--line); border-radius: 999px; padding: 7px 15px; font-size: 13px;
        font-weight: 500; color: var(--ink); background: #fff; }
      .pill b { color: var(--accent); }
      .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
        background: var(--line); border: 1px solid var(--line); margin-top: 36px; }
      .grid3 .cell { background: var(--bg); padding: 30px 26px; }
      .grid3 .num { font-family: var(--display); color: var(--accent); font-size: 15px; }
      .grid3 h3 { font-size: 20px; margin: 12px 0 8px; }
      .grid3 p { font-size: 14px; color: var(--inkSoft); }
      .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 36px; }
      .pcard { display: block; border: 1px solid var(--line); border-radius: 8px; background: #fff;
        padding: 26px 24px; transition: transform .15s ease, border-color .15s ease; }
      .pcard:hover { transform: translateY(-3px); border-color: var(--accent); }
      .pcard .tag { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); font-weight: 600; }
      .pcard h3 { font-size: 21px; margin: 8px 0 8px; }
      .pcard p { font-size: 14px; color: var(--inkSoft); }
      .prose { max-width: 720px; }
      .prose p { margin-bottom: 18px; }
      .prose h2 { font-size: clamp(24px, 3.2vw, 34px); margin: 36px 0 12px; }
      .back { font-size: 14px; color: var(--accent); font-weight: 600; }
      .field { display: block; margin-bottom: 16px; }
      .field label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
      .field input, .field textarea { width: 100%; padding: 12px 14px; border: 1px solid var(--line);
        border-radius: 4px; font: inherit; background: #fff; color: var(--ink); }
      .hp { position: absolute; left: -9999px; }
      @media (max-width: 820px) { .grid3 { grid-template-columns: 1fr; } .cards { grid-template-columns: 1fr; }
        nav.site .links { gap: 14px; font-size: 14px; } }
      /* Compact mobile header (~95px): small wordmark, tight padding, nav row
         tucked up under the logo. Desktop (>768px) is untouched. */
      @media (max-width: 768px) {
        nav.site { flex-wrap: wrap; gap: 11px; padding: 12px 16px; }
        nav.site .brand img { height: 23px; }
        nav.site .links { width: 100%; justify-content: space-between; gap: 10px; font-size: 14px; }
      }

      /* ================= WET EDGE — signature motion ==================
         Craft metaphor: a painter keeps a "wet edge" so coats blend with no
         lap marks. Here content is revealed by an advancing edge on scroll and
         key headings type in like hand-lettering. Presentation-only: all copy is
         real DOM text; only `html.js` ever hides/animates it. Honors reduced-motion. */

      /* -- Header shrink on scroll (desktop). JS toggles html.scrolled. -- */
      nav.site { transition: padding .35s cubic-bezier(.4,0,.2,1), background .35s ease, box-shadow .35s ease; }
      nav.site .brand img { transition: height .35s cubic-bezier(.4,0,.2,1); }
      @media (min-width: 769px) {
        html.scrolled nav.site {
          padding-top: 12px; padding-bottom: 12px;
          background: color-mix(in srgb, var(--bg) 94%, transparent);
          box-shadow: 0 1px 0 var(--line), 0 8px 26px rgba(34,31,28,0.07);
        }
        html.scrolled nav.site .brand img { height: 62px; }
      }

      /* -- Scroll reveal in/out. Default (no JS) = fully visible. -- */
      .js .reveal { opacity: 0; transform: translateY(22px);
        transition: opacity .7s cubic-bezier(.4,0,.2,1), transform .7s cubic-bezier(.4,0,.2,1); }
      .js .reveal.in { opacity: 1; transform: none; }
      .js .reveal.out { opacity: .35; transform: translateY(-10px); }
      .js .grid3 .cell.reveal { transition-delay: calc(var(--i, 0) * 70ms); }
      .js .cards .pcard.reveal { transition-delay: calc(var(--i, 0) * 80ms); }

      /* -- The wet edge itself: a terracotta rule that draws down beside headings. -- */
      .js .edge { position: relative; }
      .js .edge::before { content: ""; position: absolute; left: -6vw; top: .12em; bottom: .12em;
        width: 4px; background: var(--accent); transform: scaleY(0); transform-origin: top;
        transition: transform .6s cubic-bezier(.4,0,.2,1) .08s; }
      .js .edge.in::before { transform: scaleY(1); }

      /* -- Typing caret for key copy. -- */
      .js [data-type].typing::after { content: ""; display: inline-block; width: .55ch; height: .95em;
        margin-left: 3px; vertical-align: -0.08em; background: var(--accent);
        animation: weCaret .8s steps(1) infinite; }
      @keyframes weCaret { 50% { opacity: 0; } }

      /* -- Hero entrance: transform-only rise (opacity stays 1 → LCP-safe, text
            painted on the first frame), gently staggered. -- */
      .js .hero-inner > * { animation: weHeroRise .7s cubic-bezier(.4,0,.2,1) both; }
      .js .hero-inner > *:nth-child(1) { animation-delay: .02s; }
      .js .hero-inner > *:nth-child(2) { animation-delay: .10s; }
      .js .hero-inner > *:nth-child(3) { animation-delay: .18s; }
      .js .hero-inner > *:nth-child(4) { animation-delay: .26s; }
      .js .hero-inner > *:nth-child(5) { animation-delay: .34s; }
      .js .hero-inner > *:nth-child(6) { animation-delay: .42s; }
      @keyframes weHeroRise { from { transform: translateY(16px); } to { transform: none; } }

      /* -- PAINT THROW: the services section is "thrown" with paint that runs
            down and the blocks appear in its wake. The copy is real DOM text —
            only html.js clips/hides it, and only while the section is in view. -- */
      .paint-scene { position: relative; overflow: hidden; }
      .paint-throw { position: absolute; left: -6vw; right: -6vw; top: 0; bottom: 0; z-index: 5; pointer-events: none; }
      .paint-splat, .paint-edge { position: absolute; background: var(--accent); opacity: 0; }
      .paint-splat { top: -18px; border-radius: 47% 53% 44% 56% / 58% 42% 58% 42%; }
      .paint-splat.s1 { left: 24%; width: 132px; height: 98px; }
      .paint-splat.s2 { left: 60%; width: 92px; height: 74px; }
      .paint-edge { left: 0; right: 0; top: 0; height: 7px; }
      .paint-edge::before, .paint-edge::after { content: ""; position: absolute; top: 100%;
        width: 11px; background: var(--accent); border-radius: 0 0 7px 7px; }
      .paint-edge::before { left: 24%; height: 34px; }
      .paint-edge::after { left: 66%; height: 22px; box-shadow: 44px 0 0 -2px var(--accent), -140px 0 0 -3px var(--accent); }

      /* Hidden state ONLY under js. Default & no-js keep the grid + copy visible. */
      .js .paint-scene .paint-grid { clip-path: inset(0 0 100% 0); }
      .js .paint-scene .pc { opacity: 0; transform: translateY(12px); }

      .js .paint-scene.in .paint-splat.s1 { animation: weSplat .5s cubic-bezier(.2,.8,.3,1.2) forwards; }
      .js .paint-scene.in .paint-splat.s2 { animation: weSplat .5s cubic-bezier(.2,.8,.3,1.2) .08s forwards; }
      .js .paint-scene.in .paint-edge { animation: wePaintEdge 1.15s cubic-bezier(.5,0,.25,1) .18s forwards; }
      .js .paint-scene.in .paint-grid { animation: wePaintReveal 1.15s cubic-bezier(.5,0,.25,1) .18s forwards; }
      .js .paint-scene.in .pc { animation: weFadeUp .55s ease forwards; }
      .js .paint-scene.in h2.pc { animation-delay: .08s; }

      @keyframes weSplat { 0% { transform: scale(0); opacity: 1; } 65% { transform: scale(1.06); opacity: 1; } 100% { transform: scale(1); opacity: 0; } }
      @keyframes wePaintEdge { 0% { opacity: 1; top: 0; } 92% { opacity: 1; } 100% { opacity: 0; top: 100%; } }
      @keyframes wePaintReveal { to { clip-path: inset(0 0 0% 0); } }
      @keyframes weFadeUp { to { opacity: 1; transform: none; } }

      @media (prefers-reduced-motion: reduce) {
        .js .reveal, .js .reveal.in, .js .reveal.out { opacity: 1 !important; transform: none !important; transition: none !important; }
        .js .edge::before { transform: scaleY(1) !important; transition: none !important; }
        .js .hero-inner > * { animation: none !important; }
        nav.site, nav.site .brand img { transition: none !important; }
        .js [data-type].typing::after { display: none !important; }
        /* Paint throw off: show the grid + copy immediately, hide the paint layer. */
        .js .paint-scene .paint-grid { clip-path: none !important; animation: none !important; }
        .js .paint-scene .pc { opacity: 1 !important; transform: none !important; animation: none !important; }
        .paint-throw { display: none !important; }
      }
    </style>
  </head>
  <body>
    <slot />
    <script>
      // Wet Edge motion controller. Enhancement only — the page is fully readable
      // and complete without this file. Typed headings keep their real text in the
      // DOM; we cache and re-type, never remove copy from the source.
      const root = document.documentElement;
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Header shrink on scroll (desktop; CSS guards mobile height).
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          root.classList.toggle("scrolled", window.scrollY > 40);
          ticking = false;
        });
      };
      addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Type key copy in. Full text is already in the DOM (crawler-visible); we
      // cache it, clear, and retype character by character.
      const type = (el) => {
        if (el.dataset.typed) return;
        el.dataset.typed = "1";
        if (reduce) return; // reduced-motion: leave the full text untouched
        const full = el.textContent;
        el.textContent = "";
        el.classList.add("typing");
        let i = 0;
        const step = () => {
          el.textContent = full.slice(0, i);
          if (i++ < full.length) setTimeout(step, 16 + Math.random() * 26);
          else el.classList.remove("typing");
        };
        step();
      };

      // Reveal in/out on scroll. Paint scenes play once (then unobserve).
      const reveals = document.querySelectorAll(".reveal, .paint-scene");
      if (reduce || !("IntersectionObserver" in window)) {
        reveals.forEach((el) => el.classList.add("in"));
        document.querySelectorAll("[data-type]").forEach((el) => (el.dataset.typed = "1"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              const el = e.target;
              if (e.isIntersecting) {
                el.classList.add("in");
                el.classList.remove("out");
                if (el.matches("[data-type]")) type(el);
                el.querySelectorAll("[data-type]").forEach(type);
                if (el.classList.contains("paint-scene")) io.unobserve(el); // one throw only
              } else if (e.boundingClientRect.top < 0) {
                el.classList.add("out"); // settled out above the fold
              } else {
                el.classList.remove("in"); // re-arm entrance from below
              }
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
